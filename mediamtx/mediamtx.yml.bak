# MediaMTX Configuration
# https://github.com/bluenviron/mediamtx

# Paths define los streams disponibles
paths:
  # cam1: USANDO VP8 COMO PRUEBA DE COMPATIBILIDAD
  cam1:
    runOnInit: >-
      C:/Users/vinjo/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe/ffmpeg-8.0.1-full_build/bin/ffmpeg.exe -re -stream_loop -1 -i C:/Users/vinjo/remote-concierge/sample.mp4 -vf scale=640:360,fps=15 -c:v libvpx -b:v 1M -deadline realtime -cpu-used 4 -g 15 -an -f rtsp -rtsp_transport tcp rtsp://127.0.0.1:8554/cam1
    runOnInitRestart: yes
    
  # cam2 y cam3: H264
  cam2:
    runOnInit: >-
      C:/Users/vinjo/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe/ffmpeg-8.0.1-full_build/bin/ffmpeg.exe -re -stream_loop -1 -i C:/Users/vinjo/remote-concierge/sample.mp4 -vf scale=640:360,fps=15 -c:v libx264 -preset ultrafast -tune zerolatency -profile:v baseline -pix_fmt yuv420p -g 15 -an -f rtsp -rtsp_transport tcp rtsp://127.0.0.1:8554/cam2
    runOnInitRestart: yes
    
  cam3:
    runOnInit: >-
      C:/Users/vinjo/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe/ffmpeg-8.0.1-full_build/bin/ffmpeg.exe -re -stream_loop -1 -i C:/Users/vinjo/remote-concierge/sample.mp4 -vf scale=640:360,fps=15 -c:v libx264 -preset ultrafast -tune zerolatency -profile:v baseline -pix_fmt yuv420p -g 15 -an -f rtsp -rtsp_transport tcp rtsp://127.0.0.1:8554/cam3
    runOnInitRestart: yes

# WebRTC configuration
webrtc: yes
webrtcAddress: :8889
# webrtcServerPort: 8189 # Puerto ICE UDP
webrtcICEServers2: []

# RTSP para que ffmpeg publique localmente
rtspAddress: :8554

# Logging
logLevel: debug
logDestinations: [stdout]
